diff --git a/internal/httpclient/ssrf.go b/internal/httpclient/ssrf.go
new file mode 100644
index 0000000..745d54c
--- /dev/null
+++ b/internal/httpclient/ssrf.go
@@ -0,0 +1,91 @@
+package httpclient
+
+import (
+	"errors"
+	"net"
+	"net/url"
+	"sync/atomic"
+)
+
+// ErrBlockedHost is returned by GuardPublicHost when the target resolves to a
+// non-public address. It deliberately carries no host or IP detail so callers
+// can surface it to end users without turning the endpoint into an SSRF /
+// internal port-scan oracle.
+var ErrBlockedHost = errors.New("destination host is not a permitted public address")
+
+// guardDisabled, when true, makes GuardPublicHost a no-op. It is flipped only
+// by tests via DisableGuardForTest so that httptest servers (which always
+// listen on loopback) remain reachable in unit tests. Production code never
+// sets it, so the guard is always active at runtime.
+var guardDisabled atomic.Bool
+
+// DisableGuardForTest disables GuardPublicHost and returns a restore function
+// that re-enables it. Intended for use as:
+//
+//	defer httpclient.DisableGuardForTest()()
+//
+// Only tests that must dial an httptest server on loopback should call this.
+func DisableGuardForTest() (restore func()) {
+	guardDisabled.Store(true)
+	return func() { guardDisabled.Store(false) }
+}
+
+// GuardPublicHost returns a non-nil error when rawURL's host resolves to any
+// loopback, unspecified, link-local (including the 169.254.169.254 cloud
+// metadata endpoint), private (RFC1918 / RFC4193 ULA), or multicast address.
+//
+// It must be called immediately BEFORE an outbound HTTP request whose target
+// URL is operator- or DB-supplied, to prevent the management pod from being
+// used to reach cluster-internal services (Postgres/Redis), the cloud metadata
+// endpoint, or to port-scan the internal network via SSRF. On error, callers
+// should return a generic failure to the client WITHOUT echoing the URL or the
+// resolved internal address.
+func GuardPublicHost(rawURL string) error {
+	if guardDisabled.Load() {
+		return nil
+	}
+	u, err := url.Parse(rawURL)
+	if err != nil {
+		return ErrBlockedHost
+	}
+	host := u.Hostname()
+	if host == "" {
+		return ErrBlockedHost
+	}
+
+	var ips []net.IP
+	if literal := net.ParseIP(host); literal != nil {
+		ips = []net.IP{literal}
+	} else {
+		resolved, err := net.LookupIP(host)
+		if err != nil || len(resolved) == 0 {
+			// Fail closed: if the name cannot be resolved we cannot prove it
+			// is public, so we refuse rather than dial.
+			return ErrBlockedHost
+		}
+		ips = resolved
+	}
+
+	// Reject if ANY resolved address is non-public. A hostname that resolves to
+	// a mix of public and private addresses is still a valid SSRF vector.
+	for _, ip := range ips {
+		if !isPublicIP(ip) {
+			return ErrBlockedHost
+		}
+	}
+	return nil
+}
+
+// isPublicIP reports whether ip is a globally-routable public address, i.e. not
+// loopback, unspecified, link-local, private, or multicast.
+func isPublicIP(ip net.IP) bool {
+	if ip.IsLoopback() || ip.IsUnspecified() ||
+		ip.IsLinkLocalUnicast() || ip.IsLinkLocalMulticast() ||
+		ip.IsInterfaceLocalMulticast() || ip.IsMulticast() {
+		return false
+	}
+	if ip.IsPrivate() {
+		return false
+	}
+	return true
+}
diff --git a/internal/httpclient/ssrf_test.go b/internal/httpclient/ssrf_test.go
new file mode 100644
index 0000000..3dec955
--- /dev/null
+++ b/internal/httpclient/ssrf_test.go
@@ -0,0 +1,81 @@
+package httpclient
+
+import (
+	"errors"
+	"testing"
+)
+
+func TestGuardPublicHost_RejectsNonPublic(t *testing.T) {
+	// IP literals only — no DNS lookups so the test is hermetic.
+	cases := []struct {
+		name string
+		url  string
+	}{
+		{"loopback v4", "http://127.0.0.1/index.yaml"},
+		{"loopback name", "http://localhost:8088/services/collector"},
+		{"loopback v6", "http://[::1]:6379/"},
+		{"unspecified v4", "http://0.0.0.0:5432/"},
+		{"link-local metadata", "http://169.254.169.254/latest/meta-data/"},
+		{"private 10", "https://10.0.0.5/"},
+		{"private 172", "https://172.16.4.4:9000/"},
+		{"private 192", "https://192.168.1.10/"},
+		{"multicast", "http://224.0.0.1/"},
+		{"empty host", "https:///path"},
+		{"garbage", "://not a url"},
+	}
+	for _, tc := range cases {
+		t.Run(tc.name, func(t *testing.T) {
+			if err := GuardPublicHost(tc.url); err == nil {
+				t.Fatalf("GuardPublicHost(%q) = nil, want error", tc.url)
+			}
+		})
+	}
+}
+
+func TestGuardPublicHost_AllowsPublic(t *testing.T) {
+	// Public IP literals so no DNS is required.
+	cases := []string{
+		"https://8.8.8.8/",
+		"https://1.1.1.1:443/index.yaml",
+		"http://[2606:4700:4700::1111]/",
+	}
+	for _, u := range cases {
+		if err := GuardPublicHost(u); err != nil {
+			t.Fatalf("GuardPublicHost(%q) = %v, want nil", u, err)
+		}
+	}
+}
+
+func TestGuardPublicHost_ErrorIsGeneric(t *testing.T) {
+	err := GuardPublicHost("http://127.0.0.1:5432/")
+	if err == nil {
+		t.Fatal("expected error")
+	}
+	if !errors.Is(err, ErrBlockedHost) {
+		t.Fatalf("want ErrBlockedHost, got %v", err)
+	}
+	// The error must not leak the host/IP it blocked.
+	if got := err.Error(); got == "" || contains(got, "127.0.0.1") {
+		t.Fatalf("error message leaks target: %q", got)
+	}
+}
+
+func TestDisableGuardForTest(t *testing.T) {
+	restore := DisableGuardForTest()
+	if err := GuardPublicHost("http://127.0.0.1/"); err != nil {
+		t.Fatalf("guard should be disabled, got %v", err)
+	}
+	restore()
+	if err := GuardPublicHost("http://127.0.0.1/"); err == nil {
+		t.Fatal("guard should be re-enabled after restore")
+	}
+}
+
+func contains(s, sub string) bool {
+	for i := 0; i+len(sub) <= len(s); i++ {
+		if s[i:i+len(sub)] == sub {
+			return true
+		}
+	}
+	return false
+}
