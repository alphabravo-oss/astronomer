+package handler
+
+import (
+	"encoding/json"
+	"net/http"
+	"net/http/httptest"
+	"testing"
+
+	"github.com/go-chi/chi/v5"
+	"github.com/google/uuid"
+	"github.com/jackc/pgx/v5/pgtype"
+
+	"github.com/alphabravocompany/astronomer-go/internal/db/sqlc"
+	"github.com/alphabravocompany/astronomer-go/internal/rbac"
+	"github.com/alphabravocompany/astronomer-go/internal/server/middleware"
+)
+
+// TestTestOutputDeniedWithoutClusterUpdate asserts that POST
+// /api/v1/logging/outputs/{id}/test/ — which pushes Fluent Bit config to the
+// managed cluster — is gated on the output's own cluster with the logging
+// update verb, matching its apply/enable/disable/retry siblings. A zero-grant
+// viewer (logging:read only) must get 403 and must not enqueue an apply.
+func TestTestOutputDeniedWithoutClusterUpdate(t *testing.T) {
+	q := newLoggingFakeQuerier()
+	h := NewLoggingHandler(q)
+
+	clusterID := uuid.New()
+	outputID := uuid.New()
+	q.outputs[outputID] = sqlc.LoggingOutput{
+		ID:            outputID,
+		Name:          "primary-stdout",
+		OutputType:    "stdout",
+		Configuration: json.RawMessage(`{}`),
+		ClusterID:     pgtype.UUID{Bytes: clusterID, Valid: true},
+		Enabled:       true,
+	}
+
+	// Caller has read but not update on the target cluster — the
+	// authorizeClusterAction call inside TestOutput must 403.
+	h.SetAuthorization(rbac.NewEngine(), stubLoggingRBACQuerier{
+		bindings: []rbac.RoleBinding{
+			{
+				ClusterID: clusterID.String(),
+				RoleRules: []rbac.Rule{{Resource: string(rbac.ResourceLogging), Verbs: []string{string(rbac.VerbRead)}}},
+			},
+		},
+	})
+
+	req := httptest.NewRequest(http.MethodPost, "/api/v1/logging/outputs/"+outputID.String()+"/test/", nil)
+	rc := chi.NewRouteContext()
+	rc.URLParams.Add("id", outputID.String())
+	ctx := addRouteCtx(req.Context(), rc)
+	ctx = middleware.SetAuthenticatedUserForTest(ctx, &middleware.AuthenticatedUser{ID: uuid.NewString()})
+	req = req.WithContext(ctx)
+	rec := httptest.NewRecorder()
+
+	h.TestOutput(rec, req)
+
+	if rec.Code != http.StatusForbidden {
+		t.Fatalf("expected 403, got %d body=%s", rec.Code, rec.Body.String())
+	}
+	// The denied test must not have enqueued a config-push apply.
+	if len(q.operations) != 0 {
+		t.Fatalf("denied test must not enqueue an apply operation, got %d", len(q.operations))
+	}
+}
