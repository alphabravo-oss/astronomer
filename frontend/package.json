{
  "name": "astronomer-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "predev": "mkdir -p public && cp node_modules/@wterm/core/wasm/wterm.wasm public/wterm.wasm",
    "build": "vite build",
    "prebuild": "mkdir -p public && cp node_modules/@wterm/core/wasm/wterm.wasm public/wterm.wasm",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "code-health": "npm run openapi:types:check && node ../scripts/code-health-inventory.mjs --check --verify-doc && node ../scripts/operation-task-inventory.mjs --check --verify-doc",
    "openapi:types": "node ../scripts/generate-openapi-types.mjs --write",
    "openapi:types:check": "node ../scripts/generate-openapi-types.mjs --check",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --project=chromium --project=mobile-chromium",
    "pretest:e2e:smoke": "node scripts/generate-route-manifest.mjs && node scripts/generate-e2e-stubs.mjs",
    "test:e2e:smoke": "playwright test --project=route-smoke"
  },
  "dependencies": {
