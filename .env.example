# =============================================================================
# Astronomer - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
#
#   cp .env.example .env
#
# IMPORTANT: Never commit the .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Core Settings
# -----------------------------------------------------------------------------
#
# These were named DJANGO_* in the legacy Python implementation; the Go
# rewrite keeps the same purpose but uses straight names. If you have an
# old .env file with DJANGO_* variants, rename them.

# Environment: development | staging | production
ENV=development

# JWT HMAC signing key. Multiple comma-separated keys are accepted to
# support online rotation — see docs/secret-rotation-runbook.md.
# Generate with: openssl rand -base64 48
SECRET_KEY=change-me-to-a-random-secret-key

# Enable verbose debug logging. MUST be false in production.
DEBUG=false

# Comma-separated list of allowed hostnames (validated at the chart
# level via ALLOWED_HOSTS / CORS_ALLOWED_ORIGINS).
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------

# PostgreSQL connection URL
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://astronomer:astronomer@postgres:5432/astronomer

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------

# Redis connection URL (used for caching and Django Channels)
# Format: redis://HOST:PORT/DB_NUMBER
REDIS_URL=redis://redis:6379/0

# Celery broker URL (uses a separate Redis DB from the cache)
CELERY_BROKER_URL=redis://redis:6379/1

# -----------------------------------------------------------------------------
# Authentication - GitHub OAuth
# -----------------------------------------------------------------------------

# GitHub OAuth App credentials
# Create at: https://github.com/settings/applications/new
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Authentication - Google OAuth
# -----------------------------------------------------------------------------

# Google OAuth 2.0 credentials
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Authentication - OIDC (Generic OpenID Connect)
# -----------------------------------------------------------------------------

# OIDC provider issuer URL (e.g., https://accounts.google.com)
OIDC_ISSUER=

# OIDC client credentials
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Frontend - NextAuth.js
# -----------------------------------------------------------------------------

# Base URL of the Next.js application
NEXTAUTH_URL=http://localhost:3000

# Secret for NextAuth.js session encryption. Generate with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-random-nextauth-secret

# Public API URL accessible from the browser
NEXT_PUBLIC_API_URL=http://localhost/api/v1

# Public WebSocket URL accessible from the browser
NEXT_PUBLIC_WS_URL=ws://localhost/api/v1/ws

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------

# Comma-separated list of allowed origins for CORS requests
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost,https://localhost

# Comma-separated list of trusted origins for CSRF protection (required in production)
# Must include your domain with scheme, e.g.: https://astronomer.example.com
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost,https://localhost

# -----------------------------------------------------------------------------
# Observability - Sentry
# -----------------------------------------------------------------------------

# Encryption key for sensitive data (SSO secrets, API tokens).
# CRITICAL: Must be set to a stable Fernet key in production. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: Changing this key will make all previously encrypted data unrecoverable.
ASTRONOMER_ENCRYPTION_KEY=

# Sentry DSN for error tracking. Leave empty to disable.
# Get from: https://sentry.io/settings/projects/
SENTRY_DSN=

# -----------------------------------------------------------------------------
# Website / Payload CMS
# -----------------------------------------------------------------------------

# Payload CMS secret for admin authentication. Generate with:
#   openssl rand -base64 32
PAYLOAD_SECRET=change-me-to-a-random-payload-secret

# PostgreSQL connection URL for the CMS (separate from the backend database)
CMS_DATABASE_URL=postgres://astronomer:astronomer@postgres:5432/astronomer_cms

# Public URL of the website
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Session / JWT Configuration
# -----------------------------------------------------------------------------

# Session timeout in minutes. This controls how long a JWT access token is
# valid before requiring a refresh. Default: 60 (1 hour).
# The frontend auto-refreshes tokens while the user is active; this controls
# the maximum idle time before re-login is required.
SESSION_TIMEOUT_MINUTES=60

# -----------------------------------------------------------------------------
# Agent Configuration
# -----------------------------------------------------------------------------

# Container image repository for the Astronomer agent.
# For local development, this defaults to the local Docker registry.
# For production, use your own registry (e.g., ghcr.io/your-org/agent).
AGENT_IMAGE_REPOSITORY=localhost:5000/astronomer/agent

# Container image tag for the Astronomer agent
AGENT_IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# Local Docker Registry
# -----------------------------------------------------------------------------

# Port for the local Docker registry (used for serving agent images to k3s clusters)
# REGISTRY_PORT=5000

# Hostname/IP that k3s nodes use to reach this registry.
# Set this to your machine's LAN IP if k3s runs on remote nodes.
# e.g., AGENT_REGISTRY_HOST=192.168.1.100
AGENT_REGISTRY_HOST=localhost

# -----------------------------------------------------------------------------
# TLS / Certificate Configuration
# -----------------------------------------------------------------------------

# TLS mode determines how certificates are managed:
#   self-signed  - Auto-generate a self-signed certificate (default for dev)
#   letsencrypt  - Use cert-manager with Let's Encrypt (Kubernetes only)
#   custom       - Provide your own certificate files
TLS_MODE=self-signed

# Path to your TLS certificate and key (only used when TLS_MODE=custom)
# Mount these into the nginx container via docker-compose volumes
TLS_CERT_PATH=/etc/nginx/certs/server.crt
TLS_KEY_PATH=/etc/nginx/certs/server.key

# Domain name for the TLS certificate (used for self-signed cert generation)
TLS_DOMAIN=localhost

# Certificate validity in days (only for self-signed mode)
TLS_CERT_DAYS=365

# Subject Alternative Names for self-signed cert (comma-separated)
# e.g., DNS:app.example.com,DNS:*.example.com,IP:10.0.0.1
TLS_CERT_SANS=DNS:localhost,DNS:*.localhost,DNS:astronomer.local,IP:127.0.0.1

# -----------------------------------------------------------------------------
# Docker Compose Port Overrides (optional)
# -----------------------------------------------------------------------------

# Override default exposed ports if they conflict with local services
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# BACKEND_PORT=8000
# FRONTEND_PORT=3000
# WEBSITE_PORT=3001
# HTTP_PORT=80
# HTTPS_PORT=443
