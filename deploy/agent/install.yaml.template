    app.kubernetes.io/component: agent
    app.kubernetes.io/part-of: astronomer
data:
  SERVER_URL: "{{SERVER_URL}}"
  CLUSTER_ID: "{{CLUSTER_ID}}"
  HEALTH_ADDR: ":8081"
  HEARTBEAT_INTERVAL: "30"
  METRICS_INTERVAL: "60"
  PRIVILEGE_PROFILE: "{{PRIVILEGE_PROFILE}}"

---
# Installer-owned, short-lived registration bootstrap. The agent never writes
# this object. After adoption it creates and rotates the distinct durable Secret
# `astronomer-agent-token`, which is intentionally absent from this manifest.
# Reapplying this manifest can refresh bootstrap material but cannot overwrite or
# delete a valid durable identity. Apply only with the documented server-side
# field manager so plaintext is not copied into a last-applied annotation.
apiVersion: v1
kind: Secret
metadata:
  name: astronomer-agent-registration-token
  namespace: astronomer-system
  labels:
    app.kubernetes.io/name: astronomer-agent
    app.kubernetes.io/component: agent
    app.kubernetes.io/part-of: astronomer
type: Opaque
stringData:
  token: "{{REGISTRATION_TOKEN}}"

---
# Secret holding the management server's CA bundle for tunnel CA pinning.
# Populated (base64 PEM) from platform_settings[registration.ca_bundle] when a
# private/self-signed CA is in use; ca.crt is "" otherwise. The agent mounts it
# at /etc/astronomer/tls/ca.crt (volume is optional) and, when present, pins the
# tunnel against it together with ASTRONOMER_CA_CHECKSUM.
apiVersion: v1
kind: Secret
metadata:
  name: astronomer-agent-ca
  namespace: astronomer-system
  labels:
    app.kubernetes.io/name: astronomer-agent
    app.kubernetes.io/component: agent
    app.kubernetes.io/part-of: astronomer
type: Opaque
data:
  ca.crt: "{{CA_CERT}}"

---
# Deployment
apiVersion: apps/v1
kind: Deployment
metadata:
  name: astronomer-agent
  namespace: astronomer-system
  labels:
    app.kubernetes.io/name: astronomer-agent
    app.kubernetes.io/component: agent
    app.kubernetes.io/part-of: astronomer
spec:
  replicas: 1
  # Recreate, not RollingUpdate: the agent is a singleton tunnel client and the
  # server hub keys exactly one live connection per cluster_id. A surging second
  # pod (maxSurge>=1) connects alongside the old one and the two fight over that
  # single slot — each CONNECT cancels the other's session, flapping the tunnel
  # on every rollout/image bump. Recreate terminates the old pod first so there
  # is never more than one agent connected. (Mirrors Rancher cattle-cluster-agent.)
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app.kubernetes.io/name: astronomer-agent
      app.kubernetes.io/component: agent
  template:
    metadata:
      labels:
        app.kubernetes.io/name: astronomer-agent
        app.kubernetes.io/component: agent
        app.kubernetes.io/part-of: astronomer
{{AGENT_POD_LABELS}}      annotations:
        prometheus.io/scrape: "true"
        prometheus.io/port: "8081"
        prometheus.io/path: "/metrics"
    spec:
      serviceAccountName: {{AGENT_SERVICE_ACCOUNT_NAME}}
      terminationGracePeriodSeconds: 30
      securityContext:
        runAsNonRoot: true
        runAsUser: 1001
        runAsGroup: 1001
        fsGroup: 1001
        seccompProfile:
          type: RuntimeDefault
      containers:
        - name: agent
          image: "{{AGENT_IMAGE}}"
          imagePullPolicy: IfNotPresent
          command:
            - astronomer-agent
            - connect
          env:
            - name: ASTRONOMER_SERVER_URL
              valueFrom:
                configMapKeyRef:
                  name: astronomer-agent-config
                  key: SERVER_URL
            - name: ASTRONOMER_CLUSTER_ID
              valueFrom:
                configMapKeyRef:
                  name: astronomer-agent-config
                  key: CLUSTER_ID
            - name: ASTRONOMER_AGENT_TOKEN
              valueFrom:
                secretKeyRef:
                  name: astronomer-agent-registration-token
                  key: token
                  # A durable adopted agent can restart even if an operator has
                  # removed the bootstrap Secret; startup resolves durable state
                  # through the Kubernetes API before requiring this value.
                  optional: true
            - name: ASTRONOMER_BOOTSTRAP_TOKEN_SECRET_NAME
              value: "astronomer-agent-registration-token"
            - name: ASTRONOMER_BOOTSTRAP_TOKEN_SECRET_KEY
              value: "token"
            - name: ASTRONOMER_DURABLE_TOKEN_SECRET_NAME
              value: "astronomer-agent-token"
            - name: ASTRONOMER_DURABLE_TOKEN_SECRET_KEY
              value: "token"
            - name: ASTRONOMER_HEALTH_ADDR
              valueFrom:
                configMapKeyRef:
                  name: astronomer-agent-config
                  key: HEALTH_ADDR
            - name: ASTRONOMER_HEARTBEAT_INTERVAL
              valueFrom:
                configMapKeyRef:
                  name: astronomer-agent-config
                  key: HEARTBEAT_INTERVAL
            - name: ASTRONOMER_METRICS_INTERVAL
              valueFrom:
                configMapKeyRef:
                  name: astronomer-agent-config
                  key: METRICS_INTERVAL
            - name: ASTRONOMER_PRIVILEGE_PROFILE
              valueFrom:
                configMapKeyRef:
                  name: astronomer-agent-config
                  key: PRIVILEGE_PROFILE
            # Fleet-pull reconcile flag. Rendered into the Deployment (not just
            # set out-of-band) so the agent's own Phase-2 self-apply preserves it
            # — otherwise self-applying the Deployment would wipe the flag and
            # disable the reconcile loop on the next restart.
            - name: ASTRONOMER_PULL_RECONCILE_ENABLED
              value: "{{AGENT_PULL_RECONCILE_ENABLED}}"
            # Server-CA pin (Rancher CATTLE_CA_CHECKSUM semantics). Rendered into
            # the Deployment — alongside the mounted CA Secret at
            # /etc/astronomer/tls/ca.crt — so a Phase-2 self-apply preserves the
            # pin. Empty when no private CA is configured: the agent then dials
            # with the OS trust store and standard verification (no pinning).
            - name: ASTRONOMER_CA_CHECKSUM
              value: "{{CA_CHECKSUM}}"
          ports:
            - name: health
              containerPort: 8081
              protocol: TCP
          livenessProbe:
            httpGet:
              path: /healthz
              port: health
            initialDelaySeconds: 10
            periodSeconds: 30
            timeoutSeconds: 5
            failureThreshold: 3
          readinessProbe:
            httpGet:
              path: /readyz
              port: health
            initialDelaySeconds: 5
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 3
          resources:
            requests:
              cpu: 100m
              memory: 128Mi
            limits:
              cpu: 500m
              memory: 512Mi
          securityContext:
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: true
            capabilities:
              drop:
                - ALL
          volumeMounts:
            - name: ca-cert
              mountPath: /etc/astronomer/tls
              readOnly: true
            - name: tmp
              mountPath: /tmp
      volumes:
        - name: ca-cert
          secret:
            secretName: astronomer-agent-ca
            optional: true
        - name: tmp
          emptyDir:
            sizeLimit: 64Mi
      nodeSelector:
        kubernetes.io/os: linux
      tolerations:
        - key: node-role.kubernetes.io/control-plane
          operator: Exists
          effect: NoSchedule
        - key: node-role.kubernetes.io/master
          operator: Exists
          effect: NoSchedule

