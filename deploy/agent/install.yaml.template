# NetworkPolicy - allow egress to management server and Kubernetes API
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: astronomer-agent
  namespace: astronomer-system
  labels:
    app.kubernetes.io/name: astronomer-agent
    app.kubernetes.io/component: agent
    app.kubernetes.io/part-of: astronomer
spec:
  podSelector:
    matchLabels:
      app.kubernetes.io/name: astronomer-agent
      app.kubernetes.io/component: agent
  policyTypes:
    - Egress
    - Ingress
  ingress:
    # Allow health check probes from kubelet and monitoring
    - ports:
        - port: 8081
          protocol: TCP
  egress:
    # Allow DNS resolution
    - ports:
        - port: 53
          protocol: UDP
        - port: 53
          protocol: TCP
    # Allow management server traffic for both direct TLS endpoints and
    # local/dev gateways published on high ports.
    - ports:
        - port: 80
          protocol: TCP
        - port: 443
          protocol: TCP
        - port: 8080
          protocol: TCP
        - port: 8443
          protocol: TCP
    # Allow access to Kubernetes API server
    - ports:
        - port: 443
          protocol: TCP
        - port: 6443
          protocol: TCP

---
# PodDisruptionBudget (L5: honest intent). minAvailable: 0 is DELIBERATE and is
# the opposite of "always available": the agent is a single-replica, stateless
# tunnel client that reconnects on its own, so it must NEVER block a voluntary
# node drain / cluster maintenance. This PDB explicitly permits its eviction.
# (It is effectively a no-op guard; it exists so the object is present and the
# intent is documented rather than relying on the absence of a PDB.)
apiVersion: policy/v1
kind: PodDisruptionBudget
metadata:
  name: astronomer-agent
  namespace: astronomer-system
  labels:
    app.kubernetes.io/name: astronomer-agent
    app.kubernetes.io/component: agent
    app.kubernetes.io/part-of: astronomer
spec:
  minAvailable: 0
  selector:
    matchLabels:
      app.kubernetes.io/name: astronomer-agent
      app.kubernetes.io/component: agent

---
# ============================================================================
# Baseline component cluster-scoped RBAC (bootstrap-only, operator-applied once)
#
# The pull-reconcile applier is NAMESPACED-ONLY: it refuses cluster-scoped
# resources and is granted no cluster RBAC. The DefaultEnabled baseline
# component kube-state-metrics, however, must read cluster-wide inventory to
# produce its metrics. That cluster-scoped READ-ONLY grant therefore lives HERE
# in the bootstrap manifest (applied once by the operator's kubectl at
# adoption), NOT in the pulled desired state.
#
# This ClusterRole binds the kube-state-metrics ServiceAccount that the PULL
# applier creates namespaced in astronomer-monitoring. It is the ONLY
# cluster-scoped component grant besides the agent's own privilege-profile
# ClusterRole. It is get/list/watch ONLY (zero write). HONEST SCOPE (L8): this
# DOES grant cluster-wide secret READ — ksm only renders metadata-derived metrics
# (kube_secret_info/type/labels: names, namespaces, types, labels/annotations) and
# never exposes secret VALUES, but "no secret data" understates it: an
# attacker-controlled ksm pod could list every Secret object cluster-wide. This is
# the standard upstream kube-state-metrics posture; to remove it entirely, drop
# `secrets` from the rule below AND set the ksm `--resources` allowlist to exclude
# secrets (else ksm logs RBAC-forbidden noise on its secret collector). It is
# harmless when pull reconcile is disabled — just an unused read-only ClusterRole
# bound to a ServiceAccount that may not yet exist.
# ============================================================================
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: astronomer-kube-state-metrics
  labels:
    app.kubernetes.io/name: kube-state-metrics
    app.kubernetes.io/part-of: astronomer
    app.kubernetes.io/managed-by: astronomer-server
rules:
  - apiGroups: [""]
    resources: ["configmaps", "secrets", "nodes", "pods", "services", "serviceaccounts", "resourcequotas", "replicationcontrollers", "limitranges", "persistentvolumeclaims", "persistentvolumes", "namespaces", "endpoints"]
    verbs: ["get", "list", "watch"]
  - apiGroups: ["apps"]
    resources: ["statefulsets", "daemonsets", "deployments", "replicasets"]
    verbs: ["get", "list", "watch"]
  - apiGroups: ["batch"]
    resources: ["cronjobs", "jobs"]
    verbs: ["get", "list", "watch"]
  - apiGroups: ["autoscaling"]
    resources: ["horizontalpodautoscalers"]
    verbs: ["get", "list", "watch"]
  - apiGroups: ["policy"]
    resources: ["poddisruptionbudgets"]
    verbs: ["get", "list", "watch"]
  - apiGroups: ["certificates.k8s.io"]
    resources: ["certificatesigningrequests"]
    verbs: ["get", "list", "watch"]
  - apiGroups: ["storage.k8s.io"]
    resources: ["storageclasses", "volumeattachments"]
    verbs: ["get", "list", "watch"]
  - apiGroups: ["admissionregistration.k8s.io"]
    resources: ["mutatingwebhookconfigurations", "validatingwebhookconfigurations"]
    verbs: ["get", "list", "watch"]
  - apiGroups: ["networking.k8s.io"]
    resources: ["networkpolicies", "ingressclasses", "ingresses"]
    verbs: ["get", "list", "watch"]
  - apiGroups: ["coordination.k8s.io"]
    resources: ["leases"]
    verbs: ["get", "list", "watch"]
  - apiGroups: ["rbac.authorization.k8s.io"]
    resources: ["clusterrolebindings", "clusterroles", "rolebindings", "roles"]
    verbs: ["get", "list", "watch"]
  - apiGroups: ["apiextensions.k8s.io"]
    resources: ["customresourcedefinitions"]
    verbs: ["get", "list", "watch"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: astronomer-kube-state-metrics
  labels:
    app.kubernetes.io/name: kube-state-metrics
    app.kubernetes.io/part-of: astronomer
    app.kubernetes.io/managed-by: astronomer-server
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: astronomer-kube-state-metrics
subjects:
  # The ServiceAccount itself is created by the PULL applier (namespaced) in
  # astronomer-monitoring; this binding pre-exists it harmlessly.
  - kind: ServiceAccount
    name: kube-state-metrics
    namespace: astronomer-monitoring
