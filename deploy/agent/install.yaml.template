  labels:
    app.kubernetes.io/name: astronomer-agent
    app.kubernetes.io/part-of: astronomer
    app.kubernetes.io/managed-by: astronomer-server
    # L6 (the documented "real bite"): opt-in fluent-bit mounts hostPath to read
    # container logs, which baseline/restricted PSA reject. Enforce 'privileged'
    # explicitly so it schedules on PSA-enforcing clusters instead of relying on
    # an unlabeled-namespace default.
    pod-security.kubernetes.io/enforce: privileged
---
apiVersion: v1
kind: Namespace
metadata:
  name: astronomer-ingress-nginx
  labels:
    app.kubernetes.io/name: astronomer-agent
    app.kubernetes.io/part-of: astronomer
    app.kubernetes.io/managed-by: astronomer-server
    # L6: explicit PSA level. 'privileged' — opt-in third-party ingress chart
    # whose controller may need NET_BIND_SERVICE / hostPort configurations.
    pod-security.kubernetes.io/enforce: privileged
---
apiVersion: v1
kind: Namespace
metadata:
  name: astronomer-cert-manager
  labels:
    app.kubernetes.io/name: astronomer-agent
    app.kubernetes.io/part-of: astronomer
    app.kubernetes.io/managed-by: astronomer-server
    # L6: explicit PSA level for this opt-in third-party chart.
    pod-security.kubernetes.io/enforce: privileged
