# ============================================================================
# Astronomer Cluster Agent - Kubernetes Installation Manifest
#
# This template is rendered by the Astronomer management server with
# cluster-specific values. Placeholders use {{PLACEHOLDER}} syntax.
#
# Placeholders (names shown WITHOUT the double-brace syntax on purpose: the
# renderer string-replaces every literal {{...}} occurrence, so documenting
# them with braces here would inject their values — e.g. the multi-line RBAC
# rules — into this comment and break the rendered YAML):
#   SERVER_URL                   - Management server WebSocket URL
#   CLUSTER_ID                   - Unique cluster identifier
#   REGISTRATION_TOKEN           - Bearer token for agent authentication
#   CA_CERT                      - Base64-encoded CA certificate (optional)
#   AGENT_IMAGE                  - Full agent container image reference
#   AGENT_SERVICE_ACCOUNT_NAME   - Agent ServiceAccount name
#   AGENT_POD_LABELS             - Additional Deployment pod-template labels
#   AGENT_RBAC_RULES             - ClusterRole rules selected by privilege profile
#   AGENT_RBAC_BINDING_KIND      - ClusterRoleBinding or RoleBinding
#   AGENT_RBAC_BINDING_NAMESPACE - Optional namespace line for RoleBinding
#   AGENT_SELF_MANAGEMENT_NAMESPACED_RULES  - Self-management Role rules (all profiles)
#   AGENT_SELF_MANAGEMENT_DEPLOYMENT_RULES  - Own-Deployment patch rules (all profiles)
# ============================================================================

---
# Namespace
apiVersion: v1
kind: Namespace
metadata:
  name: astronomer-system
  labels:
    app.kubernetes.io/name: astronomer-agent
    app.kubernetes.io/part-of: astronomer
    app.kubernetes.io/managed-by: astronomer-server
    # L6: the agent is a well-behaved non-privileged pod, so enforce 'baseline'
    # explicitly rather than inheriting an unpredictable cluster default. (Every
    # Astronomer-owned namespace carries an explicit PSA level; the third-party
    # component namespaces are 'privileged' where their charts need it.)
    pod-security.kubernetes.io/enforce: baseline

---
# ServiceAccount
apiVersion: v1
kind: ServiceAccount
metadata:
  name: {{AGENT_SERVICE_ACCOUNT_NAME}}
  namespace: astronomer-system
  labels:
    app.kubernetes.io/name: astronomer-agent
    app.kubernetes.io/component: agent
    app.kubernetes.io/part-of: astronomer
automountServiceAccountToken: true

---
# ClusterRole - rules are rendered from the selected agent privilege profile
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: astronomer-agent
  labels:
    app.kubernetes.io/name: astronomer-agent
    app.kubernetes.io/component: agent
    app.kubernetes.io/part-of: astronomer
rules:
{{AGENT_RBAC_RULES}}

---
# RBAC binding - cluster-wide or namespace-scoped based on privilege profile
apiVersion: rbac.authorization.k8s.io/v1
kind: {{AGENT_RBAC_BINDING_KIND}}
metadata:
  name: astronomer-agent
{{AGENT_RBAC_BINDING_NAMESPACE}}  labels:
    app.kubernetes.io/name: astronomer-agent
    app.kubernetes.io/component: agent
    app.kubernetes.io/part-of: astronomer
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: astronomer-agent
subjects:
  - kind: ServiceAccount
    name: {{AGENT_SERVICE_ACCOUNT_NAME}}
    namespace: astronomer-system

---
# Namespaced Role: the agent persists rotated auth material only in its durable
# Secret. get/update/patch are resourceName-scoped. Kubernetes RBAC cannot scope
# create by resourceNames (the authorizer does not have an existing object name
# for create), so create is isolated in its own rule. Clusters that require
# name-scoped create must add the admission guard documented in
# docs/agent-credential-ownership.md. No rule in this Role permits reading or
# modifying any other existing Secret (explicit operator/admin profiles retain
# their separately documented broader user-cluster privileges).
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: astronomer-agent-token
  namespace: astronomer-system
  labels:
    app.kubernetes.io/name: astronomer-agent
    app.kubernetes.io/component: agent
    app.kubernetes.io/part-of: astronomer
rules:
  - apiGroups: [""]
    resources: ["secrets"]
    resourceNames: ["astronomer-agent-token"]
    verbs: ["get", "update", "patch"]
  - apiGroups: [""]
    resources: ["secrets"]
    verbs: ["create"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: astronomer-agent-token
  namespace: astronomer-system
  labels:
    app.kubernetes.io/name: astronomer-agent
    app.kubernetes.io/component: agent
    app.kubernetes.io/part-of: astronomer
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: Role
  name: astronomer-agent-token
subjects:
  - kind: ServiceAccount
    name: {{AGENT_SERVICE_ACCOUNT_NAME}}
    namespace: astronomer-system

---
# ============================================================================
# Astronomer SELF-MANAGEMENT RBAC (two-axis model).
#
# Axis 1 (above): the ClusterRole 'astronomer-agent' = the user-facing privilege
# profile (viewer/operator/admin/namespace-*). It governs the agent's reach into
# the CUSTOMER's resources (default/kube-system/app namespaces). A viewer is
# strictly read-only there.
#
# Axis 2 (here): namespaced Roles giving the agent WRITE over Astronomer's OWN
# footprint — agent, logging stack, and baseline platform components — bounded to
# the astronomer-* namespaces ONLY. These are emitted for EVERY profile (viewer
# included) so ArgoCD, which applies through the tunnel as the agent
# ServiceAccount, can always manage Astronomer's components regardless of how
# little the user profile grants. They are namespaced Roles (never a ClusterRole)
# so this write surface can never reach the customer's namespaces.
#
# Plus a resourceName-scoped grant on the agent's OWN Deployment so an
# Argo-driven version bump can roll the agent (mirrors the token Role pattern).
# ============================================================================

---
# Astronomer-owned namespaces for the logging stack and the relocated baseline
# platform components (monitoring, trivy, ingress-nginx, cert-manager,
# gatekeeper). Pre-created here as static Namespace objects so the
# self-management RoleBindings below have a namespace to land in even before the
# baseline reconcilers / ArgoCD ApplicationSets run — which also removes any need
# for a cluster-wide "namespaces" create verb (the appsets' CreateNamespace=true
# becomes a harmless no-op). All are fully Astronomer-managed (the decommission
# flow removes them).
apiVersion: v1
kind: Namespace
metadata:
  name: astronomer-monitoring
  labels:
    app.kubernetes.io/name: astronomer-agent
    app.kubernetes.io/part-of: astronomer
    app.kubernetes.io/managed-by: astronomer-server
    # node-exporter runs with hostNetwork/hostPID/hostPath, which the restricted
    # and baseline Pod Security Admission levels reject. This is Astronomer's own
    # metrics namespace, so enforce 'privileged' here (and only here) so the
    # DaemonSet schedules on PSA-enforcing clusters.
    pod-security.kubernetes.io/enforce: privileged
---
apiVersion: v1
kind: Namespace
metadata:
  name: astronomer-trivy-system
  labels:
    app.kubernetes.io/name: astronomer-agent
    app.kubernetes.io/part-of: astronomer
    app.kubernetes.io/managed-by: astronomer-server
    # L6: explicit PSA level (no reliance on the cluster default). 'privileged'
    # because this hosts an opt-in third-party chart whose scan jobs may need
    # securityContexts that baseline/restricted reject.
    pod-security.kubernetes.io/enforce: privileged
---
apiVersion: v1
kind: Namespace
metadata:
