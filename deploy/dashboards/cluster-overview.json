{
  "title": "Astronomer — Cluster Overview",
  "uid": "astronomer-cluster-overview",
  "schemaVersion": 38,
  "version": 1,
  "tags": ["astronomer", "kubernetes"],
  "time": {"from": "now-3h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "cluster",
        "type": "query",
        "query": "label_values(kube_node_info, cluster)",
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "title": "Nodes",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "count(kube_node_info{cluster=~\"$cluster\"})", "refId": "A"}]
    },
    {
      "title": "Pods (Running)",
      "type": "stat",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "count(kube_pod_status_phase{phase=\"Running\", cluster=~\"$cluster\"})", "refId": "A"}]
    },
    {
      "title": "Namespaces",
      "type": "stat",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "count(kube_namespace_created{cluster=~\"$cluster\"})", "refId": "A"}]
    },
    {
      "title": "PVCs (Bound)",
      "type": "stat",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "count(kube_persistentvolumeclaim_status_phase{phase=\"Bound\", cluster=~\"$cluster\"})", "refId": "A"}]
    },
    {
      "title": "Cluster CPU usage",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (cluster) (rate(node_cpu_seconds_total{mode!=\"idle\", cluster=~\"$cluster\"}[5m]))", "refId": "A"}]
    },
    {
      "title": "Cluster memory usage",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (cluster) (node_memory_MemTotal_bytes{cluster=~\"$cluster\"} - node_memory_MemAvailable_bytes{cluster=~\"$cluster\"})", "refId": "A"}]
    }
  ]
}
